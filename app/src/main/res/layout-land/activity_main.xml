<?xml version="1.0" encoding="utf-8"?>

<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/controller_background"
    android:orientation="vertical"
    android:backgroundTint="#1E1C1C"
    tools:context=".MainActivity"
    tools:ignore="MissingDefaultResource">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="end"
            android:orientation="horizontal">

            <soup.neumorphism.NeumorphCardView
                style="@style/Widget.Neumorph.CardView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:neumorph_shadowColorDark="@color/white"
                app:neumorph_shadowColorLight="@color/white"
                app:neumorph_shapeType="pressed">

                <TextView
                    android:id="@+id/connectionStatId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Device Connected"
                    android:textColor="#A30404"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    />
            </soup.neumorphism.NeumorphCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/buttonConnect"
                android:background="@drawable/bg_circular"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_bluetooth_24dp"
                android:layout_marginStart="@android:dimen/app_icon_size"
                android:contentDescription="bluetoothIcon"
                />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/infoButtonId"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/ic_baseline_info_24"
                android:contentDescription="infoButtonIcon"
                android:layout_marginEnd="10dp"
                />
        </LinearLayout>



    </LinearLayout>


    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:gravity="center"
        android:orientation="horizontal"
        android:baselineAligned="false">
        <LinearLayout
            android:contentDescription="controllerLeftSide"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <soup.neumorphism.NeumorphImageButton
                android:id="@+id/fButtonId"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_gravity="end"
                android:layout_marginEnd="@android:dimen/app_icon_size"
                android:layout_marginTop="@android:dimen/app_icon_size"
                android:src="@drawable/ic_up_arrow"
                app:tint="#74404040"
                app:neumorph_shapeType="pressed"
              />

            <soup.neumorphism.NeumorphImageButton
                android:id="@+id/bButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"
                android:layout_marginStart="@android:dimen/app_icon_size"
                android:layout_marginBottom="@android:dimen/app_icon_size"
                android:src="@drawable/ic_down_arrow"
                app:tint="#74404040"
                app:neumorph_shapeType="pressed"/>

            <!--<androidx.appcompat.widget.AppCompatButton
                android:id="@+id/fButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="end"
                android:layout_marginEnd="@android:dimen/app_icon_size"
                android:layout_marginTop="@android:dimen/app_icon_size"
                android:background="@drawable/round_button" android:textColor="#fff"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/bButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"
                android:layout_marginStart="@android:dimen/app_icon_size"
                android:layout_marginBottom="@android:dimen/app_icon_size"
                android:background="@drawable/round_button"
                android:text="B"
                android:textColor="#fff"
                android:textSize="50sp" />-->

        </LinearLayout>


        <LinearLayout
            android:contentDescription="controllerRightSide"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <soup.neumorphism.NeumorphImageButton
                android:id="@+id/lButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginLeft="@android:dimen/app_icon_size"
                android:layout_marginRight="@android:dimen/app_icon_size"
                android:src="@drawable/ic_left_arrow"
                app:tint="#74404040"
                app:neumorph_shapeType="pressed"
                />

            <soup.neumorphism.NeumorphImageButton
                android:id="@+id/rButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginEnd="@android:dimen/app_icon_size"
                android:src="@drawable/ic_right_arrow"
                app:tint="#74404040"
                app:neumorph_shapeType="pressed"
                />

           <!-- <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/lButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginLeft="@android:dimen/app_icon_size"
                android:layout_marginRight="@android:dimen/app_icon_size"
                android:background="@drawable/round_button"
                android:text="L"
                android:textColor="#fff"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/rButtonId"
                android:foreground="?android:attr/selectableItemBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginEnd="@android:dimen/app_icon_size"
                android:background="@drawable/round_button"
                android:text="R"
                android:textColor="#fff"
                android:textSize="50sp"
                android:focusable="true" />-->
        </LinearLayout>
    </LinearLayout>


</androidx.appcompat.widget.LinearLayoutCompat>